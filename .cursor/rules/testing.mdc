## Widget Tests

### Simple Widget Test

```dart
import 'package:flutter/material.dart';
import 'package:flutter_test/flutter_test.dart';
import 'package:celva/widgets/category_chip.dart';

void main() {
  group('CategoryChip', () {
    testWidgets('should display label', (tester) async {
      await tester.pumpWidget(
        MaterialApp(
          home: Scaffold(
            body: CategoryChip(
              label: 'Bushcraft',
              isSelected: false,
              onTap: () {},
            ),
          ),
        ),
      );
      
      expect(find.text('Bushcraft'), findsOneWidget);
    });
    
    testWidgets('should show selected state', (tester) async {
      await tester.pumpWidget(
        MaterialApp(
          home: Scaffold(
            body: CategoryChip(
              label: 'Featured',
              isSelected: true,
              onTap: () {},
            ),
          ),
        ),
      );
      
      final container = tester.widget<Container>(
        find.ancestor(
          of: find.text('Featured'),
          matching: find.byType(Container),
        ).first,
      );
      
      final decoration = container.decoration as BoxDecoration;
      expect(decoration.color, primaryColor);
    });
    
    testWidgets('should trigger onTap callback', (tester) async {
      bool tapped = false;
      
      await tester.pumpWidget(
        MaterialApp(
          home: Scaffold(
            body: CategoryChip(
              label: 'Test',
              isSelected: false,
              onTap: () => tapped = true,
            ),
          ),
        ),
      );
      
      await tester.tap(find.text('Test'));
      expect(tapped, true);
    });
  });
}
```

### Card Widget Test

```dart
import 'package:flutter_test/flutter_test.dart';
import 'package:celva/widgets/gear_card.dart';
import 'package:celva/models/gear_model.dart';

void main() {
  group('GearCard', () {
    final testItem = GearItem(
      id: '1',
      name: 'Tent',
      category: 'sleep',
      emoji: '⛺',
      isPacked: false,
    );
    
    testWidgets('should display gear item info', (tester) async {
      await tester.pumpWidget(
        MaterialApp(
          home: Scaffold(
            body: GearCard(item: testItem),
          ),
        ),
      );
      
      expect(find.text('Tent'), findsOneWidget);
      expect(find.text('⛺'), findsOneWidget);
    });
    
    testWidgets('should show checked state', (tester) async {
      final packedItem = testItem.copyWith(isPacked: true);
      
      await tester.pumpWidget(
        MaterialApp(
          home: Scaffold(
            body: GearCard(item: packedItem),
          ),
        ),
      );
      
      expect(find.byIcon(Icons.check), findsOneWidget);
    });
    
    testWidgets('should call onChecked callback', (tester) async {
      bool? checkedValue;
      
      await tester.pumpWidget(
        MaterialApp(
          home: Scaffold(
            body: GearCard(
              item: testItem,
              onChecked: (value) => checkedValue = value,
            ),
          ),
        ),
      );
      
      await tester.tap(find.byType(GestureDetector).last);
      expect(checkedValue, true);
    });
  });
}
```

