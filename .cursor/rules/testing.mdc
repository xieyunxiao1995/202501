## Unit Tests

### Model Tests

Test JSON serialization/deserialization:

```dart
import 'package:flutter_test/flutter_test.dart';
import 'package:celva/models/user_model.dart';

void main() {
  group('User Model', () {
    test('should create User from JSON', () {
      final json = {
        'id': '1',
        'username': 'wildhiker',
        'displayName': 'Wild Hiker',
        'followers': 1250,
        'trips': 48,
        'plans': 108,
        'tags': ['bushcraft', 'solo'],
      };
      
      final user = User.fromJson(json);
      
      expect(user.id, '1');
      expect(user.username, 'wildhiker');
      expect(user.followers, 1250);
      expect(user.tags.length, 2);
    });
    
    test('should convert User to JSON', () {
      final user = User(
        id: '1',
        username: 'wildhiker',
        followers: 1250,
        trips: 48,
        plans: 108,
      );
      
      final json = user.toJson();
      
      expect(json['id'], '1');
      expect(json['username'], 'wildhiker');
      expect(json['followers'], 1250);
    });
    
    test('should handle null values', () {
      final json = {
        'id': '1',
        'username': 'user',
        'followers': 0,
        'trips': 0,
        'plans': 0,
      };
      
      final user = User.fromJson(json);
      
      expect(user.bio, null);
      expect(user.displayName, null);
    });
    
    test('copyWith should update specified fields', () {
      final user = User(
        id: '1',
        username: 'user',
        followers: 100,
        trips: 5,
        plans: 10,
      );
      
      final updated = user.copyWith(followers: 150);
      
      expect(updated.followers, 150);
      expect(updated.username, 'user'); // unchanged
    });
  });
}
```

### Service Tests

Test business logic:

```dart
import 'package:flutter_test/flutter_test.dart';
import 'package:celva/services/data_service.dart';

void main() {
  group('DataService', () {
    late DataService dataService;
    
    setUp(() {
      dataService = DataService();
    });
    
    test('should return wiki articles', () {
      final articles = dataService.getWikiArticles();
      
      expect(articles, isNotEmpty);
      expect(articles.first, isA<WikiArticle>());
    });
    
    test('should filter articles by category', () {
      final articles = dataService.getWikiArticles(category: 'setup');
      
      expect(articles.every((a) => a.category == 'setup'), true);
    });
    
    test('should return posts with limit', () {
      final posts = dataService.getFeedPosts(limit: 5);
      
      expect(posts.length, lessThanOrEqualTo(5));
    });
  });
}
```

