## Integration Tests

Located in `integration_test/`:

```dart
import 'package:flutter_test/flutter_test.dart';
import 'package:integration_test/integration_test.dart';
import 'package:celva/main.dart' as app;

void main() {
  IntegrationTestWidgetsFlutterBinding.ensureInitialized();
  
  group('Navigation Flow', () {
    testWidgets('should navigate between tabs', (tester) async {
      app.main();
      await tester.pumpAndSettle();
      
      // Tap Plan tab
      await tester.tap(find.text('Plan'));
      await tester.pumpAndSettle();
      expect(find.text('My Plan'), findsOneWidget);
      
      // Tap Community tab
      await tester.tap(find.text('Community'));
      await tester.pumpAndSettle();
      expect(find.text('Camp Copilot'), findsOneWidget);
    });
    
    testWidgets('should navigate to detail screen', (tester) async {
      app.main();
      await tester.pumpAndSettle();
      
      // Find and tap first wiki card
      await tester.tap(find.byType(WikiCard).first);
      await tester.pumpAndSettle();
      
      // Verify detail screen
      expect(find.byType(WikiDetailScreen), findsOneWidget);
      
      // Go back
      await tester.tap(find.byIcon(Icons.arrow_back));
      await tester.pumpAndSettle();
      
      expect(find.byType(DiscoveryScreen), findsOneWidget);
    });
  });
}
```

