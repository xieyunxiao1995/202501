## GearItem Model (`gear_model.dart`)

```dart
class GearItem {
  final String id;
  final String name;
  final String category;  // sleep, cook, lighting, clothing, etc.
  final String emoji;  // Visual representation
  final String? description;
  final bool isPacked;
  final String? condition;  // cleaned, needs_repair, fragile
  final double? weight;  // in kg
  final double? value;  // in USD
  
  const GearItem({
    required this.id,
    required this.name,
    required this.category,
    required this.emoji,
    this.description,
    this.isPacked = false,
    this.condition,
    this.weight,
    this.value,
  });
  
  Map<String, dynamic> toJson();
  factory GearItem.fromJson(Map<String, dynamic> json);
  GearItem copyWith({...});
}

// Predefined categories
class GearCategory {
  static const String sleep = 'sleep';
  static const String cook = 'cook';
  static const String lighting = 'lighting';
  static const String clothing = 'clothing';
  static const String tools = 'tools';
  static const String firstAid = 'first_aid';
  static const String all = 'all';
  
  static List<String> get allCategories => [
    sleep, cook, lighting, clothing, tools, firstAid
  ];
}
