## Bottom Navigation Bar (`custom_bottom_nav.dart`)

### Design Specs
- Height: 88px (including bottom safe area)
- Background: White with top border
- Active color: Primary color (#1A3C34)
- Inactive color: Grey 400
- Icon size: 20-24px
- Label size: 10px
- Center FAB: Accent color, elevated

### Implementation Pattern
```dart
class CustomBottomNav extends StatelessWidget {
  final int currentIndex;
  final Function(int) onTap;
  
  const CustomBottomNav({
    super.key,
    required this.currentIndex,
    required this.onTap,
  });
  
  @override
  Widget build(BuildContext context) {
    return Container(
      height: 88,
      decoration: BoxDecoration(
        color: Colors.white,
        border: Border(top: BorderSide(color: Colors.grey[100]!)),
      ),
      child: SafeArea(
        child: Row(
          mainAxisAlignment: MainAxisAlignment.spaceAround,
          children: [
            _buildNavItem(0, Icons.explore, 'Discovery'),
            _buildNavItem(1, Icons.map, 'Plan'),
            _buildCenterFAB(),
            _buildNavItem(3, Icons.forum, 'Community'),
            _buildNavItem(4, Icons.person, 'Profile'),
          ],
        ),
      ),
    );
  }
  
  Widget _buildNavItem(int index, IconData icon, String label) {
    final isActive = currentIndex == index;
    return GestureDetector(
      onTap: () => onTap(index),
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(
            icon,
            size: 24,
            color: isActive ? primaryColor : Colors.grey[400],
          ),
          SizedBox(height: 4),
          Text(
            label,
            style: TextStyle(
              fontSize: 10,
              color: isActive ? primaryColor : Colors.grey[400],
              fontWeight: isActive ? FontWeight.w600 : FontWeight.normal,
            ),
          ),
        ],
      ),
    );
  }
  
  Widget _buildCenterFAB() {
    return Container(
      width: 56,
      height: 56,
      decoration: BoxDecoration(
        color: accentColor,
        shape: BoxShape.circle,
        boxShadow: [
          BoxShadow(
            color: accentColor.withOpacity(0.3),
            blurRadius: 12,
            offset: Offset(0, 4),
          ),
        ],
      ),
      child: IconButton(
        icon: Icon(Icons.add, color: Colors.white, size: 28),
        onPressed: () => onTap(2),
      ),
    );
  }
}
```

